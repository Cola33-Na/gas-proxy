{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://script.google.com/macros/s/AKfycbxxxxxxxx/exec/$1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
